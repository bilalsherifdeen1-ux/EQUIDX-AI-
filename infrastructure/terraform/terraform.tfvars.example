environment            = "production"
aws_region             = "us-east-1"
vpc_cidr               = "10.20.0.0/16"
kubernetes_version     = "1.30"
node_instance_types    = ["t3.large"]
min_nodes              = 3
max_nodes              = 10
rds_instance_class     = "db.t3.medium"
rds_allocated_storage  = 50
redis_node_type        = "cache.t3.micro"
