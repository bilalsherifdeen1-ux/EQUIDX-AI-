      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "type": "graph",
      "title": "5xx error rate",
      "targets": [{ "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) by (job)" }],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    }
  ],
